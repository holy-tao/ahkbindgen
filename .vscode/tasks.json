{
  "version": "2.0.0",
  "tasks": [
    {
        "label": "Bundle",
        "type": "shell",
        "command": "ahkbuild bundle exe -v",
        "group": {
            "kind": "build",
            "isDefault": true
        },
        "options": {
            "shell": {
                "executable": "powershell.exe",
                "args": ["-NoProfile", "-Command"]
            }
        },
    },
    {
        "label": "Run Unit Tests",
        "type": "shell",
        "command": "ahkbuild run ${workspaceFolder}\\tests\\RunTests.ahk -v",
        "group": {
            "kind": "test",
            "isDefault": true
        },
        "options": {
            "shell": {
                "executable": "powershell.exe",
                "args": ["-NoProfile", "-Command"]
            }
        }
    }
  ]
}